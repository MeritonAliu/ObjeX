@inject DialogService DialogService
@inject IJSRuntime JS

<RadzenStack Gap="1rem" Style="padding:1rem; min-width:400px" @onkeydown="OnKeyDown" tabindex="-1">
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Share this password securely — it expires in 72 hours.
    </RadzenAlert>

    <div>
        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">Temporary Password</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <code style="flex:1; padding:0.5rem; background:var(--rz-base-100); border-radius:var(--rz-border-radius); font-size:0.875rem; word-break:break-all">@Password</code>
            <RadzenButton Icon="@_copyIcon" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" Click="CopyToClipboard" />
        </RadzenStack>
    </div>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Done" ButtonStyle="ButtonStyle.Primary" Click="@(() => DialogService.Close(null))" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string Password { get; set; } = string.Empty;

    string _copyIcon = "content_copy";

    async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Password);
        _copyIcon = "check";
        StateHasChanged();
        await Task.Delay(2000);
        _copyIcon = "content_copy";
        StateHasChanged();
    }

    void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "Escape") DialogService.Close(null);
    }
}
