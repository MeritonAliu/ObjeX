@inject DialogService DialogService
@inject IJSRuntime JS

<RadzenStack Gap="1rem" Style="padding:1rem; min-width:400px" @onkeydown="OnKeyDown" tabindex="-1">
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Save your secret access key now — it won't be shown again.
    </RadzenAlert>

    <div>
        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">Access Key ID</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <code style="flex:1; padding:0.5rem; background:var(--rz-base-100); border-radius:var(--rz-border-radius); font-size:0.875rem; word-break:break-all">@AccessKeyId</code>
            <RadzenButton Icon="@_copyKeyIcon" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" Click="@(() => CopyToClipboard(AccessKeyId, "key"))" />
        </RadzenStack>
    </div>

    <div>
        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">Secret Access Key</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <code style="flex:1; padding:0.5rem; background:var(--rz-base-100); border-radius:var(--rz-border-radius); font-size:0.875rem; word-break:break-all">@SecretAccessKey</code>
            <RadzenButton Icon="@_copySecretIcon" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" Click="@(() => CopyToClipboard(SecretAccessKey, "secret"))" />
        </RadzenStack>
    </div>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Done" ButtonStyle="ButtonStyle.Primary" Click="@(() => DialogService.Close(null))" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string AccessKeyId { get; set; } = string.Empty;
    [Parameter] public string SecretAccessKey { get; set; } = string.Empty;

    string _copyKeyIcon = "content_copy";
    string _copySecretIcon = "content_copy";

    async Task CopyToClipboard(string value, string which)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
        if (which == "key") { _copyKeyIcon = "check"; StateHasChanged(); await Task.Delay(2000); _copyKeyIcon = "content_copy"; }
        else                { _copySecretIcon = "check"; StateHasChanged(); await Task.Delay(2000); _copySecretIcon = "content_copy"; }
        StateHasChanged();
    }

    void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "Escape") DialogService.Close(null);
    }
}
