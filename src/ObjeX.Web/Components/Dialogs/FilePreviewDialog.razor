<div class="preview-container">
    @if (IsImage)
    {
        <img src="@Url" alt="@FileName" style="max-width:100%;max-height:70vh;display:block;margin:0 auto;border-radius:4px" />
    }
    else if (IsVideo)
    {
        <video controls style="max-width:100%;max-height:70vh;display:block;margin:0 auto">
            <source src="@Url" type="@ContentType" />
        </video>
    }
    else if (IsAudio)
    {
        <div style="padding:2rem 0;display:flex;justify-content:center">
            <audio controls style="width:100%">
                <source src="@Url" type="@ContentType" />
            </audio>
        </div>
    }
    else if (IsPdf)
    {
        <iframe src="@(Url + "#pagemode=none&toolbar=0")" style="width:100%;height:70vh;border:none;border-radius:4px" />
    }
    else if (IsText)
    {
        <iframe src="@Url" style="width:100%;height:70vh;border:none;border-radius:4px" />
    }
</div>

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
             AlignItems="AlignItems.Center" Style="margin-top:1rem">
    <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">@ContentType</RadzenText>
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
        <a href="@(Url + "?download=true")" download="@FileName" target="_blank" style="text-decoration:none">
            <RadzenButton Text="Download" Icon="download" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" />
        </a>
        <RadzenButton Text="Close" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                      Click="@(() => DialogService.Close())" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string FileName { get; set; } = string.Empty;
    [Parameter] public string ContentType { get; set; } = string.Empty;
    [Parameter] public string Url { get; set; } = string.Empty;

    [Inject] DialogService DialogService { get; set; } = null!;

    bool IsImage => ContentType.StartsWith("image/");
    bool IsVideo => ContentType.StartsWith("video/");
    bool IsAudio => ContentType.StartsWith("audio/");
    bool IsPdf   => ContentType == "application/pdf";
    bool IsText  => ContentType.StartsWith("text/");
}
