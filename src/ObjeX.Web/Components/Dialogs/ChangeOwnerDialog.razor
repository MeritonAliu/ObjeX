@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ObjeX.Core.Models
@inject DialogService DialogService
@inject UserManager<User> UserManager

<RadzenStack Gap="1rem" Style="padding:1rem; min-width:320px">
    <RadzenText>
        Change owner of <strong>@Bucket.Name</strong>
    </RadzenText>
    <div>
        <label style="display:block; margin-bottom:0.25rem; font-size:0.875rem">New owner</label>
        <RadzenDropDown @bind-Value="_selectedUserId" Data="_users"
                        TextProperty="@nameof(UserOption.UserName)"
                        ValueProperty="@nameof(UserOption.Id)"
                        Style="width:100%" />
    </div>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary"
                      Disabled="@(_selectedUserId == Bucket.OwnerId)"
                      Click="OnSave" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public Bucket Bucket { get; set; } = null!;

    record UserOption(string Id, string UserName);

    public record Result(string UserId, string UserName);

    List<UserOption> _users = [];
    string _selectedUserId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var allUsers = await UserManager.Users
            .Where(u => !u.IsDeactivated)
            .OrderBy(u => u.UserName)
            .ToListAsync();

        _users = allUsers
            .Select(u => new UserOption(u.Id, u.UserName ?? u.Id))
            .ToList();

        _selectedUserId = Bucket.OwnerId;
    }

    void OnSave()
    {
        var selected = _users.FirstOrDefault(u => u.Id == _selectedUserId);
        if (selected is null) return;
        DialogService.Close(new Result(selected.Id, selected.UserName));
    }
}
