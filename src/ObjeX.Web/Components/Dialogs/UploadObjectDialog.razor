@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IJSRuntime JS

<RadzenStack Gap="1rem">
    <div @ref="_dropZoneRef"
         style="position:relative; display:flex; flex-direction:column; align-items:center; justify-content:center;
                border: 2px dashed var(--rz-primary); border-radius: var(--rz-border-radius);
                padding: 2rem; gap:0.5rem; background: var(--rz-base-background-color);
                min-height: 120px;
                @(_files.Count > 0 ? "display:none" : "")">
        <span class="rzi rzi-upload" style="font-size:2rem; color:var(--rz-primary)"></span>
        <RadzenText TextStyle="TextStyle.Subtitle1">Drag &amp; drop file(s) here or click to browse</RadzenText>
        <InputFile @ref="_inputFileRef" OnChange="OnFilesSelected" multiple
                   style="position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%" />
    </div>

    @if (_files.Count > 0)
    {
        <RadzenStack Gap="0.5rem">
            @foreach (var f in _files)
            {
                <RadzenCard>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack Gap="0.1rem">
                            <RadzenText TextStyle="TextStyle.Subtitle2">@f.Name</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption">@FileHelper.FormatBytes(f.Size)</RadzenText>
                        </RadzenStack>
                        <span class="rzi rzi-check-circle" style="color:var(--rz-success); font-size:1.25rem"></span>
                    </RadzenStack>
                </RadzenCard>
            }
        </RadzenStack>
        <RadzenButton Text="@(_files.Count == 1 ? "Choose a different file" : "Choose different files")"
                      ButtonStyle="ButtonStyle.Light" Icon="refresh" Click="@(() => _files = [])" />
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="@($"Upload {(_files.Count > 0 ? $"({_files.Count} {(_files.Count == 1 ? "file" : "files")})" : "")}")"
                      ButtonStyle="ButtonStyle.Primary" Click="@OnUpload"
                      Disabled="@(_files.Count == 0)" />
    </RadzenStack>
</RadzenStack>

@code {
    public record UploadFile(string Name, string ContentType, long Size, IBrowserFile BrowserFile);

    ElementReference _dropZoneRef;
    InputFile? _inputFileRef;
    IJSObjectReference? _module;

    List<IBrowserFile> _files = [];

    const long MaxFileSize = 500L * 1024 * 1024;
    const int MaxFiles = 10;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Dialogs/UploadObjectDialog.razor.js");
            await _module.InvokeVoidAsync("initDropZone", _dropZoneRef, _inputFileRef!.Element);
        }
    }

    void OnFilesSelected(InputFileChangeEventArgs e)
    {
        if (e.FileCount > MaxFiles)
        {
            _files = [];
            NotificationService.Notify(NotificationSeverity.Warning, "Too many files",
                $"Selected {e.FileCount} files. Maximum is {MaxFiles} at a time.");
            return;
        }
        _files = e.GetMultipleFiles(MaxFiles).ToList();
    }

    void OnUpload()
    {
        var result = _files.Select(f => new UploadFile(f.Name, f.ContentType, f.Size, f)).ToList();
        DialogService.Close(result);
    }
}
