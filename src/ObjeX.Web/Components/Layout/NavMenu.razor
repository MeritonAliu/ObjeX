@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization

<RadzenStack Style="height:100%; padding:0.5rem 0" JustifyContent="JustifyContent.SpaceBetween">
    <RadzenPanelMenu>
        <RadzenPanelMenuItem Text="Dashboard" Path="/" Icon="dashboard" />
        <RadzenPanelMenuItem Text="Buckets" Path="/buckets" Icon="storage" />
<RadzenPanelMenuItem Text="Hangfire" Path="/hangfire" Icon="schedule" />
        <RadzenPanelMenuItem Text="Settings" Path="/settings" Icon="build" />
    </RadzenPanelMenu>

    <div style="border-top:1px solid var(--rz-border-disabled-color)">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="@_username" Path="/profile" Icon="manage_accounts" />
            <RadzenPanelMenuItem Text="Sign out" Icon="logout"
                                 Click="@(() => Navigation.NavigateTo("/account/logout", forceLoad: true))" />
        </RadzenPanelMenu>
    </div>
</RadzenStack>

@code {
    string _username = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _username = auth.User.Identity?.Name ?? "Unknown";
    }
}
