@page "/change-password"
@layout EmptyLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using ObjeX.Core.Models
@attribute [Authorize]
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Change Password — ObjeX</PageTitle>

<div style="display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--rz-base-background-color)">
    <RadzenCard Style="width:400px">
        <RadzenStack Gap="1.5rem">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.H5" style="margin:0">ObjeX</RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" style="color:var(--rz-text-secondary-color)">Change your password to continue</RadzenText>
            </RadzenStack>

            <RadzenStack Gap="0.75rem">
                <input class="rz-textbox" style="width:100%" type="password"
                       placeholder="New password" @bind="_newPassword" @bind:event="oninput" @onkeydown="OnKeyDown" />
                <input class="rz-textbox" style="width:100%" type="password"
                       placeholder="Confirm new password" @bind="_confirmPassword" @bind:event="oninput" @onkeydown="OnKeyDown" />
                <span style="font-size:0.75rem; color:var(--rz-danger); visibility:@(_error is not null ? "visible" : "hidden")">
                    @(_error ?? "\u00a0")
                </span>
                <button class="rz-button rz-button-md rz-primary" style="width:100%"
                        disabled="@(!CanSubmit)" @onclick="OnSubmit">
                    Set Password
                </button>
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>
</div>

@code {
    User? _user;
    string _newPassword = string.Empty;
    string _confirmPassword = string.Empty;
    string? _error;

    bool CanSubmit => !string.IsNullOrWhiteSpace(_newPassword) && !string.IsNullOrWhiteSpace(_confirmPassword);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _user = await UserManager.FindByIdAsync(userId!);

        // Guard: if user doesn't need to change password, send them home
        if (_user is null || !_user.MustChangePassword)
            Navigation.NavigateTo("/", forceLoad: true);
    }

    async Task OnSubmit()
    {
        _error = null;

        if (_newPassword.Length < 4)
        {
            _error = "Password must be at least 4 characters.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(_user!);
        var result = await UserManager.ResetPasswordAsync(_user!, token, _newPassword);
        if (!result.Succeeded)
        {
            _error = result.Errors.First().Description;
            return;
        }

        _user!.MustChangePassword = false;
        _user.TemporaryPasswordExpiresAt = null;
        await UserManager.UpdateAsync(_user);

        Navigation.NavigateTo("/", forceLoad: true);
    }

    void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSubmit) _ = OnSubmit();
    }
}
